# Production example values. Point these to managed or remote infrastructure.
APP_ENV=production
OUTPUT_DIR=reports

ENABLE_CPU_PROFILE=true
ENABLE_ELAPSED_TIME=true
ENABLE_MEMORY_CHECK=true
ENABLE_DATABASE_PROFILE=true
TOP_N_FUNCTIONS=30
MEMORY_LEAK_ITERATIONS=3

DB_HOST=your-production-postgres-host
DB_PORT=5432
DB_NAME=dbkr
DB_USER=app_user
DB_PASSWORD=change-me
DB_TEST_QUERY=SELECT 1
