# Example environment variables shared by local machine, Docker, or deployed server runs.
APP_ENV=local
OUTPUT_DIR=reports

ENABLE_CPU_PROFILE=true
ENABLE_ELAPSED_TIME=true
ENABLE_MEMORY_CHECK=true
ENABLE_DATABASE_PROFILE=true
TOP_N_FUNCTIONS=30
MEMORY_LEAK_ITERATIONS=3

DB_HOST=localhost
DB_PORT=5432
DB_NAME=dbkr
DB_USER=postgres
DB_PASSWORD=postgres
DB_TEST_QUERY=SELECT 1
